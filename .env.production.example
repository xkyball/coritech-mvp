# CoriTech production example.
# Production credentials must never be committed, emailed, or pasted into
# markdown. Store them in a CoriTech-controlled secret manager or future vault.

CORITECH_ENVIRONMENT=production

APP_BASE_URL=https://app.example.invalid
API_BASE_URL=https://api.example.invalid
DATABASE_URL=replace-in-production-secret-manager
AUDIT_LOG_RETENTION_DAYS=365

AUTH_PROVIDER_CLIENT_ID=replace-in-production-secret-manager
AUTH_PROVIDER_CLIENT_SECRET=replace-in-production-secret-manager
# Google hosted login issuer. Use a production OAuth Web client with
# https://api.example.invalid/auth/callback authorized.
AUTH_PROVIDER_DOMAIN=https://accounts.google.com
# Recommended in production: set a separate high-entropy session signing secret.
# AUTH_SESSION_SECRET=replace-in-production-secret-manager

EMAIL_PROVIDER=http_api
EMAIL_PROVIDER_API_KEY=replace-in-production-secret-manager
EMAIL_PROVIDER_ENDPOINT=replace-with-coritech-controlled-email-provider-endpoint
EMAIL_FROM_ADDRESS=notifications@example.invalid
EMAIL_FROM_NAME=CoriTech

MONITORING_PROVIDER=http_api
MONITORING_ENDPOINT=replace-with-coritech-controlled-monitoring-endpoint
ERROR_TRACKING_DSN=replace-in-production-secret-manager

OBJECT_STORAGE_PROVIDER=s3-compatible
OBJECT_STORAGE_ENDPOINT=replace-with-coritech-controlled-storage-endpoint
OBJECT_STORAGE_PORT=443
OBJECT_STORAGE_USE_SSL=true
OBJECT_STORAGE_BUCKET=replace-with-production-bucket-name
OBJECT_STORAGE_REGION=replace-with-production-storage-region
OBJECT_STORAGE_ACCESS_KEY=replace-in-production-secret-manager
OBJECT_STORAGE_SECRET_KEY=replace-in-production-secret-manager

PAYMENT_PROVIDER_SECRET=replace-in-production-secret-manager
LOGISTICS_PROVIDER_API_KEY=replace-in-production-secret-manager
