# CoriTech Phase 1 MVP environment contract.
# Copy this file to a real local .env file only for development use, or start
# from one of the environment-specific examples:
# - .env.local.example
# - .env.staging.example
# - .env.production.example
#
# Never commit real secrets, local .env files, staging values, or production
# values. Secrets must be injected through environment variables or a future
# CoriTech-controlled secrets vault.
# TODO(secrets-vault): Select and document the CoriTech-owned secrets manager
# before any live staging or production deployment.

CORITECH_ENVIRONMENT=local

# Core application URLs
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Core data
DATABASE_URL=postgresql://127.0.0.1:5432/coritech_phase1

# Audit and retention
AUDIT_LOG_RETENTION_DAYS=30

# Managed authentication provider placeholders.
# Keep placeholder values until Ticket 2.1 selects and integrates the provider.
AUTH_PROVIDER_CLIENT_ID=replace-before-managed-auth-setup
AUTH_PROVIDER_CLIENT_SECRET=replace-before-managed-auth-setup
AUTH_PROVIDER_DOMAIN=replace-before-managed-auth-setup

# Email provider placeholder.
# Keep as a placeholder until Ticket 9.1 implements the provider integration.
EMAIL_PROVIDER_API_KEY=replace-before-email-provider-setup

# Object storage placeholders.
# Bucket naming may change after the storage provider is selected.
OBJECT_STORAGE_BUCKET=coritech-local-dev
OBJECT_STORAGE_ACCESS_KEY=replace-before-object-storage-setup
OBJECT_STORAGE_SECRET_KEY=replace-before-object-storage-setup

# Payment reference placeholder.
# Ticket 10.2 may use this for reference-only payment workflows later.
PAYMENT_PROVIDER_SECRET=replace-before-payment-provider-setup

# Logistics provider placeholder.
# Keep as a placeholder until the adapter ticket selects a provider.
LOGISTICS_PROVIDER_API_KEY=replace-before-logistics-provider-setup
