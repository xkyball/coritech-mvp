# CoriTech staging example.
# Do not use this file as-is for deployment. Move the same variable names into
# a CoriTech-controlled secret manager or future secrets vault.

CORITECH_ENVIRONMENT=staging

APP_BASE_URL=https://staging.app.example.invalid
API_BASE_URL=https://staging.api.example.invalid
DATABASE_URL=replace-in-staging-secret-manager
AUDIT_LOG_RETENTION_DAYS=90

AUTH_PROVIDER_CLIENT_ID=replace-in-staging-secret-manager
AUTH_PROVIDER_CLIENT_SECRET=replace-in-staging-secret-manager
AUTH_PROVIDER_DOMAIN=replace-with-managed-auth-domain

EMAIL_PROVIDER_API_KEY=replace-in-staging-secret-manager

OBJECT_STORAGE_BUCKET=replace-with-staging-bucket-name
OBJECT_STORAGE_ACCESS_KEY=replace-in-staging-secret-manager
OBJECT_STORAGE_SECRET_KEY=replace-in-staging-secret-manager

PAYMENT_PROVIDER_SECRET=replace-in-staging-secret-manager
LOGISTICS_PROVIDER_API_KEY=replace-in-staging-secret-manager
