generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED

  @@map("coritech_user_status")
}

enum OrganizationStatus {
  ACTIVE
  DISABLED

  @@map("coritech_organization_status")
}

enum OrganizationType {
  BREEDER
  BREEDING_STATION
  PLATFORM

  @@map("coritech_organization_type")
}

enum RolePhase {
  PHASE_1
  FUTURE_PREPARED

  @@map("coritech_role_phase")
}

enum RoleCode {
  BREEDER
  BREEDING_STATION
  PLATFORM_ADMIN
  VET
  FEDERATION
  SALES_VENUE
  BUYER
  TECH_SUPPORT

  @@map("coritech_role_code")
}

enum StallionStatus {
  ACTIVE
  INACTIVE

  @@map("coritech_stallion_status")
}

enum SemenAvailabilityStatus {
  AVAILABLE
  LIMITED
  UNAVAILABLE

  @@map("coritech_semen_availability_status")
}

enum SemenListingStatus {
  ACTIVE
  INACTIVE

  @@map("coritech_semen_listing_status")
}

enum SemenOrderStatus {
  DRAFT
  SUBMITTED
  RECEIVED
  CONFIRMED
  REJECTED
  IN_FULFILMENT
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED

  @@map("coritech_semen_order_status")
}

enum ShipmentStatus {
  PREPARED
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  DELAYED
  FAILED
  CANCELLED

  @@map("coritech_shipment_status")
}

enum ShipmentTrackingEventSource {
  MANUAL
  LOGISTICS_PROVIDER
  SYSTEM

  @@map("coritech_shipment_tracking_event_source")
}

enum DocumentAccessClassification {
  INTERNAL
  ORDER_PARTICIPANTS
  RESTRICTED
  BUYER_VIEW_ELIGIBLE
  ADMIN_ONLY

  @@map("coritech_document_access_classification")
}

enum DocumentLinkTargetType {
  SemenOrder
  Shipment
  ProofEvent

  @@map("coritech_document_link_target_type")
}

enum DocumentStatus {
  ACTIVE
  SUPERSEDED
  REVOKED

  @@map("coritech_document_status")
}

enum ProofEventType {
  SEMEN_ORDER_CREATED
  SUBMITTED
  CONFIRMED
  REJECTED
  SHIPMENT_CREATED
  SHIPMENT_STATUS_UPDATED
  SHIPMENT_CONFIRMED
  DOCUMENT_UPLOADED
  ORDER_COMPLETED
  ADMIN_CORRECTION_CREATED

  @@map("coritech_proof_event_type")
}

enum ProofEventSource {
  ORDER_STATUS_CHANGE
  SHIPMENT_TRACKING_EVENT
  DOCUMENT_UPLOAD
  ADMIN_CORRECTION

  @@map("coritech_proof_event_source")
}

enum ProofEventStatus {
  RECORDED
  VOIDED

  @@map("coritech_proof_event_status")
}

enum VerificationLevelCode {
  SELF_REPORTED
  SYSTEM_RECORDED
  STATION_CONFIRMED
  ADMIN_REVIEWED
  VET_SIGNED
  FEDERATION_ATTESTED
  VERIFIED_FOR_TRANSACTION

  @@map("coritech_verification_level")
}

enum AuditLogAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  UPLOAD_DOCUMENT
  VIEW_DOCUMENT
  ACCESS_DECISION
  CREATE_PROOF_EVENT
  CHANGE_PERMISSION
  ADMIN_EDIT
  CREATE_AMENDMENT
  LOGIN
  LOGOUT

  @@map("coritech_audit_log_action")
}

enum UserInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED

  @@map("coritech_user_invitation_status")
}

enum UserInvitationEmailStatus {
  QUEUED
  SENT
  FAILED

  @@map("coritech_user_invitation_email_status")
}

enum OrderActivityType {
  SYSTEM_STATUS
  USER_COMMENT
  INTERNAL_NOTE
  SUPPORT_NOTE

  @@map("coritech_order_activity_type")
}

enum OrderActivityVisibility {
  SHARED
  STATION_INTERNAL
  ADMIN_INTERNAL

  @@map("coritech_order_activity_visibility")
}

enum SupportRequestObjectType {
  SemenOrder

  @@map("coritech_support_request_object_type")
}

enum SupportRequestCategory {
  ORDER_STATUS
  DOCUMENT_ACCESS
  SHIPMENT
  PAYMENT_REFERENCE
  ACCOUNT_ACCESS
  OTHER

  @@map("coritech_support_request_category")
}

enum SupportRequestStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED

  @@map("coritech_support_request_status")
}

enum SupportRequestNotificationStatus {
  QUEUED
  SENT
  FAILED

  @@map("coritech_support_request_notification_status")
}

enum NotificationChannel {
  EMAIL

  @@map("coritech_notification_channel")
}

enum NotificationDeliveryStatus {
  QUEUED
  SENT
  FAILED
  RETRY_PENDING

  @@map("coritech_notification_delivery_status")
}

enum PaymentReferenceStatus {
  NOT_REQUIRED
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED

  @@map("coritech_payment_reference_status")
}

enum AmendmentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED

  @@map("coritech_amendment_status")
}

enum AmendmentTargetType {
  SemenOrder
  OrderStatusHistory
  Shipment
  ShipmentTrackingEvent
  Document
  EvidenceAttachment
  ProofEvent

  @@map("coritech_amendment_target_type")
}

enum AccessPermissionScope {
  VIEW
  CREATE
  UPDATE
  CONFIRM
  UPLOAD_DOCUMENT
  VIEW_DOCUMENT
  ADMIN_SUPPORT
  BUYER_VIEW

  @@map("coritech_access_permission_scope")
}

model User {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  managedAuthSubject String     @unique @map("managed_auth_subject")
  email              String     @unique
  displayName        String     @map("display_name")
  status             UserStatus @default(ACTIVE)
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

model Organization {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  organizationType OrganizationType   @map("organization_type")
  status           OrganizationStatus @default(ACTIVE)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("organizations")
}

model Role {
  code                 RoleCode  @id
  phase                RolePhase
  displayName          String    @map("display_name")
  description          String
  isAssignableInPhase1 Boolean   @default(false) @map("is_assignable_in_phase_1")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("roles")
}

model VerificationLevel {
  code             VerificationLevelCode @id
  displayName      String                @map("display_name")
  description      String
  isActiveInPhase1 Boolean               @default(false) @map("is_active_in_phase_1")
  sortOrder        Int                   @map("sort_order")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("verification_levels")
}

model UserOrganizationRole {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  roleCode           RoleCode  @map("role_code")
  assignedByUserId   String    @map("assigned_by_user_id") @db.Uuid
  assignmentReason   String?   @map("assignment_reason")
  effectiveAt        DateTime  @default(now()) @map("effective_at") @db.Timestamptz(6)
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedByUserId    String?   @map("revoked_by_user_id") @db.Uuid
  revocationReason   String?   @map("revocation_reason")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId, organizationId], map: "user_organization_roles_user_lookup")
  @@index([organizationId, roleCode], map: "user_organization_roles_organization_lookup")
  @@index([assignedByUserId, createdAt], map: "user_organization_roles_assigned_by_lookup")
  @@map("user_organization_roles")
}

model UserInvitation {
  id                       String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String
  organizationId           String                    @map("organization_id") @db.Uuid
  organizationName         String?                   @map("organization_name")
  roleCode                 RoleCode                  @map("role_code")
  status                   UserInvitationStatus      @default(PENDING)
  tokenHash                String                    @unique @map("token_hash")
  expiresAt                DateTime                  @map("expires_at") @db.Timestamptz(6)
  invitedByUserId          String                    @map("invited_by_user_id") @db.Uuid
  invitedByOrganizationId  String                    @map("invited_by_organization_id") @db.Uuid
  acceptedAt               DateTime?                 @map("accepted_at") @db.Timestamptz(6)
  acceptedUserId           String?                   @map("accepted_user_id") @db.Uuid
  acceptedRoleAssignmentId String?                   @map("accepted_role_assignment_id") @db.Uuid
  revokedAt                DateTime?                 @map("revoked_at") @db.Timestamptz(6)
  revokedByUserId          String?                   @map("revoked_by_user_id") @db.Uuid
  revocationReason         String?                   @map("revocation_reason")
  emailDeliveryStatus      UserInvitationEmailStatus @default(QUEUED) @map("email_delivery_status")
  emailQueuedAt            DateTime?                 @map("email_queued_at") @db.Timestamptz(6)
  emailSentAt              DateTime?                 @map("email_sent_at") @db.Timestamptz(6)
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([email, status, expiresAt], map: "user_invitations_email_status_lookup")
  @@index([organizationId, status, expiresAt], map: "user_invitations_organization_lookup")
  @@index([invitedByUserId, createdAt], map: "user_invitations_inviter_lookup")
  @@map("user_invitations")
}

model Stallion {
  id                                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  breedingStationOrganizationId       String         @map("breeding_station_organization_id") @db.Uuid
  breedingStationOrganizationType     OrganizationType @default(BREEDING_STATION) @map("breeding_station_organization_type")
  name                                String
  breed                               String
  ueln                                String?
  microchipNumber                     String?        @map("microchip_number")
  status                              StallionStatus @default(ACTIVE)
  createdByUserId                     String         @map("created_by_user_id") @db.Uuid
  updatedByUserId                     String         @map("updated_by_user_id") @db.Uuid
  createdAt                           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([id, breedingStationOrganizationId], map: "stallions_id_station_unique")
  @@index([breedingStationOrganizationId, status], map: "stallions_station_lookup")
  @@map("stallions")
}

model SemenListing {
  id                            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stallionId                    String                  @map("stallion_id") @db.Uuid
  breedingStationOrganizationId String                  @map("breeding_station_organization_id") @db.Uuid
  availabilityStatus            SemenAvailabilityStatus @default(AVAILABLE) @map("availability_status")
  listingStatus                 SemenListingStatus      @default(ACTIVE) @map("listing_status")
  termsSummary                  String?                 @map("terms_summary")
  createdByUserId               String                  @map("created_by_user_id") @db.Uuid
  updatedByUserId               String                  @map("updated_by_user_id") @db.Uuid
  createdAt                     DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([id, breedingStationOrganizationId], map: "semen_listings_id_station_unique")
  @@index([breedingStationOrganizationId, listingStatus, availabilityStatus], map: "semen_listings_station_lookup")
  @@index([stallionId, listingStatus], map: "semen_listings_stallion_lookup")
  @@map("semen_listings")
}

model SemenOrder {
  id                              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber                     String           @unique @default(dbgenerated("generate_semen_order_number()")) @map("order_number")
  semenListingId                  String           @map("semen_listing_id") @db.Uuid
  breederOrganizationId           String           @map("breeder_organization_id") @db.Uuid
  breederOrganizationType         OrganizationType @default(BREEDER) @map("breeder_organization_type")
  breedingStationOrganizationId   String           @map("breeding_station_organization_id") @db.Uuid
  breedingStationOrganizationType OrganizationType @default(BREEDING_STATION) @map("breeding_station_organization_type")
  status                          SemenOrderStatus @default(DRAFT)
  requestedDeliveryDate           DateTime?        @map("requested_delivery_date") @db.Date
  mareName                        String?          @map("mare_name")
  mareRegistrationReference       String?          @map("mare_registration_reference")
  mareBreed                       String?          @map("mare_breed")
  mareOwnerName                   String?          @map("mare_owner_name")
  intendedInseminationContext     String?          @map("intended_insemination_context")
  vetOrRecipientContact           String?          @map("vet_or_recipient_contact")
  shippingContactName             String?          @map("shipping_contact_name")
  shippingContactPhone            String?          @map("shipping_contact_phone")
  shippingAddressLine1            String?          @map("shipping_address_line_1")
  shippingAddressLine2            String?          @map("shipping_address_line_2")
  shippingCity                    String?          @map("shipping_city")
  shippingRegion                  String?          @map("shipping_region")
  shippingPostalCode              String?          @map("shipping_postal_code")
  shippingCountry                 String?          @map("shipping_country")
  specialInstructions             String?          @map("special_instructions")
  createdByUserId                 String           @map("created_by_user_id") @db.Uuid
  updatedByUserId                 String           @map("updated_by_user_id") @db.Uuid
  createdAt                       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([id, orderNumber], map: "semen_orders_id_order_number_unique")
  @@unique([id, orderNumber, breederOrganizationId, breedingStationOrganizationId], map: "semen_orders_shipment_reference_unique")
  @@index([breederOrganizationId, status, createdAt], map: "semen_orders_breeder_lookup")
  @@index([breedingStationOrganizationId, status, createdAt], map: "semen_orders_station_lookup")
  @@index([semenListingId, status], map: "semen_orders_listing_lookup")
  @@map("semen_orders")
}

model PaymentReference {
  id                            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  semenOrderId                  String                 @map("semen_order_id") @db.Uuid
  orderNumber                   String                 @map("order_number")
  breederOrganizationId         String                 @map("breeder_organization_id") @db.Uuid
  breedingStationOrganizationId String                 @map("breeding_station_organization_id") @db.Uuid
  providerName                  String?                @map("provider_name")
  providerReferenceId           String?                @map("provider_reference_id")
  status                        PaymentReferenceStatus @default(PENDING)
  amount                        Decimal?               @db.Decimal(12, 2)
  currency                      String?                @db.Char(3)
  createdByUserId               String                 @map("created_by_user_id") @db.Uuid
  updatedByUserId               String                 @map("updated_by_user_id") @db.Uuid
  createdAt                     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([semenOrderId, providerName, providerReferenceId], map: "payment_references_order_provider_reference_unique")
  @@index([semenOrderId, updatedAt], map: "payment_references_order_lookup")
  @@index([status, updatedAt], map: "payment_references_status_lookup")
  @@index([providerName, providerReferenceId], map: "payment_references_provider_lookup")
  @@map("payment_references")
}

model OrderActivity {
  id                        String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  semenOrderId              String                  @map("semen_order_id") @db.Uuid
  orderNumber               String                  @map("order_number")
  type                      OrderActivityType
  visibility                OrderActivityVisibility @default(SHARED)
  message                   String
  createdByUserId           String?                 @map("created_by_user_id") @db.Uuid
  createdByOrganizationId   String?                 @map("created_by_organization_id") @db.Uuid
  createdByRole             RoleCode?               @map("created_by_role")
  createdAt                 DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([semenOrderId, createdAt, id], map: "order_activities_order_timeline")
  @@index([createdByUserId, createdAt], map: "order_activities_actor_lookup")
  @@index([visibility, createdAt], map: "order_activities_visibility_lookup")
  @@map("order_activities")
}

model SupportRequest {
  id                        String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  objectType                SupportRequestObjectType         @map("object_type")
  objectId                  String                           @map("object_id") @db.Uuid
  objectRef                 Json                             @default("{}") @map("object_ref")
  category                  SupportRequestCategory
  message                   String
  status                    SupportRequestStatus             @default(OPEN)
  createdByUserId           String                           @map("created_by_user_id") @db.Uuid
  createdByOrganizationId   String                           @map("created_by_organization_id") @db.Uuid
  createdByRole             RoleCode                         @map("created_by_role")
  adminNotificationStatus   SupportRequestNotificationStatus @default(QUEUED) @map("admin_notification_status")
  adminNotificationQueuedAt DateTime?                        @map("admin_notification_queued_at") @db.Timestamptz(6)
  createdAt                 DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, updatedAt], map: "support_requests_status_lookup")
  @@index([objectType, objectId], map: "support_requests_object_lookup")
  @@index([createdByOrganizationId, createdAt], map: "support_requests_organization_lookup")
  @@map("support_requests")
}

model NotificationLog {
  id                      String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType               String                     @map("event_type")
  templateId              String                     @map("template_id")
  channel                 NotificationChannel        @default(EMAIL)
  recipientRule           String                     @map("recipient_rule")
  recipientUserId         String?                    @map("recipient_user_id") @db.Uuid
  recipientOrganizationId String?                    @map("recipient_organization_id") @db.Uuid
  recipientRole           RoleCode?                  @map("recipient_role")
  recipientRef            Json                       @default("{}") @map("recipient_ref")
  payload                 Json                       @default("{}")
  status                  NotificationDeliveryStatus @default(QUEUED)
  providerMessageId       String?                    @map("provider_message_id")
  attemptCount            Int                        @default(0) @map("attempt_count")
  nextRetryAt             DateTime?                  @map("next_retry_at") @db.Timestamptz(6)
  lastError               String?                    @map("last_error")
  createdAt               DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([eventType, createdAt], map: "notification_logs_event_lookup")
  @@index([templateId, createdAt], map: "notification_logs_template_lookup")
  @@index([status, nextRetryAt], map: "notification_logs_status_retry_lookup")
  @@map("notification_logs")
}

model OrderStatusHistory {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  semenOrderId          String            @map("semen_order_id") @db.Uuid
  orderNumber           String            @map("order_number")
  fromStatus            SemenOrderStatus? @map("from_status")
  toStatus              SemenOrderStatus  @map("to_status")
  actorUserId           String            @map("actor_user_id") @db.Uuid
  actorRoleCode         RoleCode          @map("actor_role_code")
  actorOrganizationId   String            @map("actor_organization_id") @db.Uuid
  reason                String?
  changedAt             DateTime          @default(now()) @map("changed_at") @db.Timestamptz(6)

  @@index([semenOrderId, changedAt, id], map: "order_status_history_order_timeline")
  @@index([actorUserId, changedAt], map: "order_status_history_actor_lookup")
  @@map("order_status_history")
}

model Shipment {
  id                            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  semenOrderId                  String         @map("semen_order_id") @db.Uuid
  orderNumber                   String         @map("order_number")
  breederOrganizationId         String         @map("breeder_organization_id") @db.Uuid
  breedingStationOrganizationId String         @map("breeding_station_organization_id") @db.Uuid
  status                        ShipmentStatus @default(PREPARED)
  providerName                  String?        @map("provider_name")
  providerTrackingId            String?        @map("provider_tracking_id")
  trackingUrl                   String?        @map("tracking_url")
  deliveredAt                   DateTime?      @map("delivered_at") @db.Timestamptz(6)
  confirmedReceivedAt           DateTime?      @map("confirmed_received_at") @db.Timestamptz(6)
  confirmedByUserId             String?        @map("confirmed_by_user_id") @db.Uuid
  confirmationSource            String?        @map("confirmation_source")
  createdByUserId               String         @map("created_by_user_id") @db.Uuid
  updatedByUserId               String         @map("updated_by_user_id") @db.Uuid
  createdAt                     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([id, semenOrderId, orderNumber], map: "shipments_id_order_number_unique")
  @@index([semenOrderId, createdAt], map: "shipments_order_lookup")
  @@index([breedingStationOrganizationId, status, updatedAt], map: "shipments_station_status_lookup")
  @@index([breederOrganizationId, updatedAt], map: "shipments_breeder_lookup")
  @@map("shipments")
}

model ShipmentTrackingEvent {
  id                    String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId            String                      @map("shipment_id") @db.Uuid
  semenOrderId          String                      @map("semen_order_id") @db.Uuid
  orderNumber           String                      @map("order_number")
  fromStatus            ShipmentStatus?             @map("from_status")
  toStatus              ShipmentStatus              @map("to_status")
  eventSource           ShipmentTrackingEventSource @default(MANUAL) @map("event_source")
  sourceEventId         String?                     @map("source_event_id")
  providerStatus        String?                     @map("provider_status")
  location              String?
  notes                 String?
  actorUserId           String                      @map("actor_user_id") @db.Uuid
  actorRoleCode         RoleCode                    @map("actor_role_code")
  actorOrganizationId   String                      @map("actor_organization_id") @db.Uuid
  occurredAt            DateTime                    @default(now()) @map("occurred_at") @db.Timestamptz(6)
  recordedAt            DateTime                    @default(now()) @map("recorded_at") @db.Timestamptz(6)

  @@index([shipmentId, occurredAt, id], map: "shipment_tracking_events_timeline")
  @@index([semenOrderId, occurredAt], map: "shipment_tracking_events_order_lookup")
  @@index([eventSource, occurredAt], map: "shipment_tracking_events_source_lookup")
  @@map("shipment_tracking_events")
}

model Document {
  id                            String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentType                  String                       @map("document_type")
  description                   String?
  targetType                    DocumentLinkTargetType       @map("target_type")
  targetId                      String                       @map("target_id") @db.Uuid
  semenOrderId                  String?                      @map("semen_order_id") @db.Uuid
  shipmentId                    String?                      @map("shipment_id") @db.Uuid
  proofEventId                  String?                      @map("proof_event_id") @db.Uuid
  orderNumber                   String?                      @map("order_number")
  breederOrganizationId         String?                      @map("breeder_organization_id") @db.Uuid
  breedingStationOrganizationId String?                      @map("breeding_station_organization_id") @db.Uuid
  originalFileName              String                       @map("original_file_name")
  contentType                   String                       @map("content_type")
  fileSizeBytes                 BigInt                       @map("file_size_bytes")
  checksumSha256                String?                      @map("checksum_sha256")
  storageProvider               String                       @map("storage_provider")
  storageBucket                 String                       @map("storage_bucket")
  storageObjectKey              String                       @map("storage_object_key")
  storageRegion                 String?                      @map("storage_region")
  storageVersionId              String?                      @map("storage_version_id")
  accessClassification          DocumentAccessClassification @map("access_classification")
  status                        DocumentStatus               @default(ACTIVE)
  replacedByDocumentId          String?                      @map("replaced_by_document_id") @db.Uuid
  revocationReason              String?                      @map("revocation_reason")
  replacementReason             String?                      @map("replacement_reason")
  lifecycleChangedAt            DateTime?                    @map("lifecycle_changed_at") @db.Timestamptz(6)
  lifecycleChangedByUserId      String?                      @map("lifecycle_changed_by_user_id") @db.Uuid
  lifecycleChangedByRoleCode    RoleCode?                    @map("lifecycle_changed_by_role_code")
  lifecycleChangedByOrganizationId String?                   @map("lifecycle_changed_by_organization_id") @db.Uuid
  uploadedByUserId              String                       @map("uploaded_by_user_id") @db.Uuid
  uploaderRoleCode              RoleCode                     @map("uploader_role_code")
  uploaderOrganizationId        String                       @map("uploader_organization_id") @db.Uuid
  createdAt                     DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([id, targetType, targetId], map: "documents_id_target_unique")
  @@index([status, createdAt], map: "documents_status_lookup")
  @@index([accessClassification, createdAt], map: "documents_access_lookup")
  @@index([storageProvider, storageBucket, storageObjectKey], map: "documents_storage_reference_lookup")
  @@map("documents")
}

