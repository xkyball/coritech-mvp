{
  "name": "@coritech/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/client.ts",
  "scripts": {
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "npm run db:generate && prisma db seed --schema prisma/schema.prisma",
    "db:reset": "npm run db:generate && prisma migrate reset --force --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "prisma": "6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
